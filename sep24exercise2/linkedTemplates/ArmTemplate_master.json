{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "sep24exercise2"
		},
		"AzureBloblinkedservice_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'AzureBloblinkedservice'"
		},
		"SqlServerlinkedservie_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'SqlServerlinkedservie'"
		},
		"SqlServerlinkedservie_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "LAPTOP-SRPRH5B1"
		},
		"SqlServerlinkedservie_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "practice"
		},
		"SqlServerlinkedservie_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "prabhakar"
		},
		"sharedselfIR_properties_typeProperties_linkedInfo_resourceId": {
			"type": "string",
			"defaultValue": "/subscriptions/1693b4f5-75a9-4581-8cc0-10266837daa3/resourcegroups/RG1TestGroup/providers/Microsoft.DataFactory/factories/Sep24PracticeADF/integrationruntimes/selfhostedIR"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "sep24exercise2_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"AzureBloblinkedservice_connectionString": {
						"value": "[parameters('AzureBloblinkedservice_connectionString')]"
					},
					"SqlServerlinkedservie_password": {
						"value": "[parameters('SqlServerlinkedservie_password')]"
					},
					"sharedselfIR_properties_typeProperties_linkedInfo_resourceId": {
						"value": "[parameters('sharedselfIR_properties_typeProperties_linkedInfo_resourceId')]"
					},
					"SqlServerlinkedservie_properties_typeProperties_server": {
						"value": "[parameters('SqlServerlinkedservie_properties_typeProperties_server')]"
					},
					"SqlServerlinkedservie_properties_typeProperties_database": {
						"value": "[parameters('SqlServerlinkedservie_properties_typeProperties_database')]"
					},
					"SqlServerlinkedservie_properties_typeProperties_userName": {
						"value": "[parameters('SqlServerlinkedservie_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}